# Données (volumineuses, à reproduire localement)
data/1-raw/*
data/2-processed/*
data/gum_raw/*
data/crossner_raw/*
!data/1-raw/.gitkeep
!data/2-processed/.gitkeep
!data/gum_raw/.gitkeep
!data/crossner_raw/.gitkeep
!data/1-raw/*.py
!data/2-processed/*.py

# Outputs : models fittés, résultats (volumineux), sauf l'agrégat du benchmark
# (results_all.json, ~24 Ko) qui alimente toutes les tables du papier.
outputs/models/*
outputs/results/*
!outputs/models/.gitkeep
!outputs/results/.gitkeep
!outputs/results/aggregate/
outputs/results/aggregate/*
!outputs/results/aggregate/results_all.json

# OWNER baseline (upstream : https://github.com/alteca/OWNER, commit d1e6cb7).
# Le code upstream n'est pas versionné ici : on ne garde que nos configs LyRIDS
# et les fichiers patchés (ajoutés une fois avec `git add -f`, restent suivis
# ensuite). Reconstruction : voir external/README.md.
external/OWNER/*
!external/OWNER/configs/
external/OWNER/configs/*
!external/OWNER/configs/lyrids/
!external/OWNER/configs/lyrids_ner/

# MLflow (si on l'ajoute plus tard)
mlruns/
mlartifacts/
mlflow.db
mlflow.db-journal

# Python
__pycache__/
*.py[cod]
*.so
*.egg-info/
build/
dist/

# Environments
.venv/
venv/
env/
.env

# IDE
.vscode/
.idea/
.history/

# Tests / type-checkers
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage

# Jupyter
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

# HuggingFace cache local
.hf_cache/

*.zip

# LaTeX build artifacts (paper)
paper/*.aux
paper/*.log
paper/*.out
paper/*.bbl
paper/*.blg
paper/*.toc
paper/*.synctex.gz
paper/sections/*.aux

# Scratch render PNGs at paper/ root (real figures live in assets/)
paper/*.png
paper/.tmp/
# LaTeX build artifacts (KBS_paper)
KBS_paper/*.aux
KBS_paper/*.log
KBS_paper/*.out
KBS_paper/*.bbl
KBS_paper/*.blg
KBS_paper/*.toc
KBS_paper/*.spl
KBS_paper/*.synctex.gz
KBS_paper/sections/*.aux
# Scratch render PNGs at KBS_paper/ root (real figures live in assets/)
KBS_paper/*.png
KBS_paper/.tmp/
KBS_paper/Example of KDS paper.pdf